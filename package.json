{
  "name": "core",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--import tsx/esm\" webpack serve",
    "build:dev": "NODE_OPTIONS=\"--import tsx/esm\" webpack --env mode=development",
    "build:prod": "NODE_OPTIONS=\"--import tsx/esm\" webpack --env mode=production",
    "lint": "NODE_OPTIONS=\"--import tsx/esm\" eslint src",
    "lint:fix": "NODE_OPTIONS=\"--import tsx/esm\" eslint src --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "prettier": "prettier --check \"src/**/*.{ts,tsx,css,scss,json}\"",
    "prettier:fix": "prettier --write \"src/**/*.{ts,tsx,css,scss,json}\"",
    "format": "npm run prettier:fix && npm run lint:fix && npm run stylelint:fix",
    "unit": "NODE_OPTIONS=\"\" jest",
    "unit:watch": "NODE_OPTIONS=\"\" jest --watch",
    "unit:coverage": "NODE_OPTIONS=\"\" jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kstokken99/core.git"
  },
  "keywords": [
    "webpack",
    "typescript",
    "react"
  ],
  "author": "@a.ivanov",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kstokken99/core/issues"
  },
  "homepage": "https://github.com/kstokken99/core#readme",
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@types/webpack-dev-server": "^4.7.1",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.6.7",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jiti": "^2.7.0",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.8.3",
    "react-i18next": "^17.0.6",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "stylelint": "^17.11.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "typescript-eslint": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/eslint-plugin": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/parser": {
      "eslint": "$eslint"
    }
  }
}
